rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ───────────────────────────────────────────────────────────────

    function isSuperAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/superAdmins/$(request.auth.uid));
    }

    // True when the authenticated user is the admin of a specific clinic doc.
    function isClinicAdmin(clinicId) {
      return request.auth != null &&
        request.auth.uid == get(/databases/$(database)/documents/clinics/$(clinicId)).data.adminUid;
    }

    // True when the authenticated user owns the clinic that this appointment belongs to.
    function ownsAppointmentClinic() {
      return request.auth != null &&
        request.auth.uid ==
          get(/databases/$(database)/documents/clinics/$(resource.data.clinicId)).data.adminUid;
    }

    function clinicIsActive(clinicId) {
      return exists(/databases/$(database)/documents/clinics/$(clinicId)) &&
        get(/databases/$(database)/documents/clinics/$(clinicId)).data.active == true;
    }

    function appointmentPath(appointmentId) {
      return /databases/$(database)/documents/appointments/$(appointmentId);
    }

    function canCreateAppointment() {
      return clinicIsActive(request.resource.data.clinicId) &&
        request.resource.id == request.resource.data.lookupKey &&
        request.resource.data.status == 'pending' &&
        request.resource.data.bookingRef is string &&
        request.resource.data.phone is string &&
        request.resource.data.date is string &&
        request.resource.data.time is string;
    }

    function canSelfServeAppointment() {
      let changed = request.resource.data.diff(resource.data).changedKeys();
      return resource.data.status in ['pending', 'confirmed'] &&
        request.resource.data.clinicId == resource.data.clinicId &&
        request.resource.data.lookupKey == resource.data.lookupKey &&
        request.resource.data.bookingRef == resource.data.bookingRef &&
        request.resource.data.name == resource.data.name &&
        request.resource.data.phone == resource.data.phone &&
        request.resource.data.email == resource.data.email &&
        request.resource.data.doctorId == resource.data.doctorId &&
        request.resource.data.doctorName == resource.data.doctorName &&
        request.resource.data.createdAt == resource.data.createdAt &&
        changed.hasOnly(['service', 'date', 'time', 'message', 'status', 'updatedAt']) &&
        request.resource.data.status in ['pending', 'cancelled'];
    }

    function canCreateSlot() {
      let appointment = getAfter(appointmentPath(request.resource.data.appointmentId));
      return request.resource.data.keys().hasOnly([
        'clinicId', 'doctorId', 'date', 'time', 'appointmentId', 'createdAt', 'updatedAt'
      ]) &&
        appointment.data.clinicId == request.resource.data.clinicId &&
        appointment.data.date == request.resource.data.date &&
        appointment.data.time == request.resource.data.time &&
        appointment.data.doctorId == request.resource.data.doctorId;
    }

    function canDeleteSlot() {
      let appointment = getAfter(appointmentPath(resource.data.appointmentId));
      return appointment.data.status == 'cancelled' ||
        appointment.data.date != resource.data.date ||
        appointment.data.time != resource.data.time ||
        appointment.data.doctorId != resource.data.doctorId;
    }

    // ── Clinics ───────────────────────────────────────────────────────────────
    // Public read is intentionally wide: APP_INITIALIZER loads clinic config on
    // every visitor's browser. Sensitive billing/auth fields are stored in the
    // private subcollection below so they are never exposed to patients.
    //
    // Create: super admins only — self-signup goes through the server-side
    //         Admin SDK which bypasses these rules.
    // Update/delete: the clinic's own admin OR a platform super admin.
    match /clinics/{clinicId} {
      allow read:   if true;
      allow create: if isSuperAdmin();
      allow update: if isClinicAdmin(clinicId) || isSuperAdmin();
      allow delete: if isSuperAdmin();

      // ── Sensitive billing / auth data (never exposed to patients) ─────────
      // Stored separately so `allow read: if true` on the parent doc is safe.
      match /private/{docId} {
        allow read, write: if isClinicAdmin(clinicId) || isSuperAdmin();
      }

      // ── Doctors subcollection ─────────────────────────────────────────────
      match /doctors/{doctorId} {
        allow read:  if true;
        allow write: if isClinicAdmin(clinicId) || isSuperAdmin();
      }
    }

    // ── Appointments ──────────────────────────────────────────────────────────
    // create/read: unauthenticated — patients book and look up by ref+phone.
    //
    // update: the clinic admin who OWNS this appointment's clinic, OR a super
    //         admin. Any other authenticated user (e.g. a different clinic's
    //         doctor) is explicitly denied.
    //
    // delete: super admin only — clinic admins cancel via status update, not
    //         hard delete, so patient records are preserved.
    match /appointments/{appointmentId} {
      allow create: if canCreateAppointment();
      allow get:    if true;
      allow list:   if ownsAppointmentClinic() || isSuperAdmin();
      allow update: if ownsAppointmentClinic() || isSuperAdmin() || canSelfServeAppointment();
      allow delete: if isSuperAdmin();
    }

    // ── Contacts ─────────────────────────────────────────────────────────────
    // Public create: submitted via the unauthenticated contact form on clinic
    // sites and the platform landing page. Sensitive data (read/edit/delete)
    // is restricted to super admins only.
    match /contacts/{docId} {
      allow create: if true;
      allow read, update, delete: if isSuperAdmin();
    }

    // ── Leads ─────────────────────────────────────────────────────────────────
    // Platform CRM — super admin only. Clinic admins must NOT be able to read
    // the platform's prospect pipeline.
    match /leads/{leadId} {
      allow read, write: if isSuperAdmin();

      match /activities/{activityId} {
        allow read, write: if isSuperAdmin();
      }
    }

    // ── Super Admins ──────────────────────────────────────────────────────────
    match /superAdmins/{uid} {
      allow read:  if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // ── Analytics / counters ──────────────────────────────────────────────────
    // Public write: booking flow atomically increments counters without auth.
    // Field validation ensures only legitimate counter fields can be written —
    // prevents arbitrary data injection while keeping the write unauthenticated.
    // Read: super admin only (shown on Revenue / Analytics pages).
    match /analytics/{docId} {
      allow read:  if isSuperAdmin();
      allow write: if request.resource.data.keys().hasOnly([
        'totalBookings', 'totalRevenue', 'activeClinics',
        'trialClinics', 'cancelledClinics', 'updatedAt',
        'dailyBookings', 'monthlyRevenue', 'clinicId', 'date'
      ]);
    }

    // ── Platform settings ─────────────────────────────────────────────────────
    match /platform/{docId} {
      allow read, write: if isSuperAdmin();
    }

    // ── Notification queue (trial expiry emails, reminders) ───────────────────
    // Written server-side via Admin SDK; client never reads or writes directly.
    match /notifications/{docId} {
      allow read, write: if false;
    }

    // ── Slots (atomic slot reservations for double-booking prevention) ────────
    // Written atomically by the booking transaction. Readable publicly (booking
    // form needs to check availability). Only the owning clinic admin can delete.
    match /slots/{slotId} {
      allow read:   if true;
      allow create: if canCreateSlot();
      allow delete: if canDeleteSlot() || (request.auth != null &&
        request.auth.uid ==
          get(/databases/$(database)/documents/clinics/$(resource.data.clinicId)).data.adminUid);
      allow update: if false;
    }
  }
}
