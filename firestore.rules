rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper ────────────────────────────────────────────────────────────────
    function isSuperAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/superAdmins/$(request.auth.uid));
    }

    // ── Clinics ───────────────────────────────────────────────────────────────
    // Public read: APP_INITIALIZER loads clinic config on any visitor's domain.
    // Create: super admins only (self-signup goes through server-side Admin SDK).
    // Update/delete: the clinic's own admin OR a platform super admin.
    match /clinics/{clinicId} {
      allow read: if true;
      allow create: if isSuperAdmin();
      allow update, delete: if request.auth != null && (
        request.auth.uid == resource.data.adminUid ||
        isSuperAdmin()
      );

      // ── Doctors subcollection ──────────────────────────────────────────────
      match /doctors/{doctorId} {
        allow read: if true;
        allow write: if request.auth != null && (
          request.auth.uid == get(/databases/$(database)/documents/clinics/$(clinicId)).data.adminUid ||
          isSuperAdmin()
        );
      }
    }

    // ── Appointments ──────────────────────────────────────────────────────────
    // create/read: unauthenticated (patients book online and look up by ref+phone)
    // update/delete: authenticated admins only (confirm / cancel / complete)
    match /appointments/{appointmentId} {
      allow create, read: if true;
      allow update, delete: if request.auth != null;
    }

    // ── Contacts ─────────────────────────────────────────────────────────────
    // create: public (contact form is unauthenticated)
    // manage: super admin only
    match /contacts/{docId} {
      allow create: if true;
      allow read, update, delete: if isSuperAdmin();
    }

    // ── Leads ─────────────────────────────────────────────────────────────────
    // Platform CRM — authenticated users only.
    // Activities subcollection must be matched explicitly (rules do not cascade).
    match /leads/{leadId} {
      allow read, write: if request.auth != null;

      match /activities/{activityId} {
        allow read, write: if request.auth != null;
      }
    }

    // ── Super Admins ──────────────────────────────────────────────────────────
    // Users may only read their own doc to verify platform-admin role.
    // No client writes — records are seeded via Firebase Admin SDK only.
    match /superAdmins/{uid} {
      allow read:  if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // ── Analytics / counters ──────────────────────────────────────────────────
    // Public write: booking flow atomically increments counters without auth.
    // Read: authenticated only (admin dashboards).
    match /analytics/{docId} {
      allow read:  if request.auth != null;
      allow write: if true;
    }

    // ── Platform settings ─────────────────────────────────────────────────────
    // Super admin only — stores monthly cost figures for the Revenue page.
    match /platform/{docId} {
      allow read, write: if isSuperAdmin();
    }
  }
}
