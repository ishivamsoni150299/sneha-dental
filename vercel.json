{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/mydentalplatform/browser",
  "framework": null,
  "rewrites": [
    { "source": "/robots.txt",      "destination": "/api/seo?type=robots" },
    { "source": "/sitemap.xml",     "destination": "/api/seo?type=sitemap" },
    { "source": "/business",        "destination": "/business/index.html" },
    { "source": "/business/",       "destination": "/business/index.html" },
    { "source": "/api/(.*)",         "destination": "/api/$1" },
    { "source": "/__/auth/(.*)",     "destination": "https://sneha-dental-6373b.firebaseapp.com/__/auth/$1" },
    { "source": "/__/firebase/(.*)", "destination": "https://sneha-dental-6373b.firebaseapp.com/__/firebase/$1" },
    { "source": "/(.*)",             "destination": "/index.html" }
  ],
  "crons": [
    {
      "path":     "/api/cron-trial-expiry",
      "schedule": "30 2 * * *"
    }
  ],
  "functions": {
    "api/self-signup.ts":        { "maxDuration": 20 },
    "api/cron-trial-expiry.ts":  { "maxDuration": 30 },
    "api/elevenlabs.ts":         { "maxDuration": 30 },
    "api/domain.ts":             { "maxDuration": 15 }
  }
}
