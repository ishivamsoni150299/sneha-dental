# ─────────────────────────────────────────────────────────────────────────────
# My Dental Platform — Environment Variables
#
# All variables below are set in Vercel Dashboard → Project → Settings →
# Environment Variables. For local development, copy this file to .env.local
# and fill in the values. .env.local is gitignored — NEVER commit real keys.
#
# NOTE: The Angular client-side Firebase config (apiKey, appId, authDomain,
# etc.) lives in src/environments/environment.ts — those are PUBLIC keys
# designed to be in browser code. They are safe to commit.
# ─────────────────────────────────────────────────────────────────────────────

# ── Firebase Admin SDK (server-side only — used by /api/ serverless functions)
# Download from: Firebase Console → Project Settings → Service Accounts →
#                Generate new private key → download JSON
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── Anthropic (Claude Haiku — AI text receptionist chat)
# Get key at: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=

# ── ElevenLabs (AI voice receptionist)
# Get key at: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
# Webhook secret — create a random string and enter the SAME value in:
#   ElevenLabs Dashboard → Webhooks → add endpoint → secret
ELEVENLABS_WEBHOOK_SECRET=

# ── Razorpay (subscription billing)
# Get keys at: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Webhook secret — create a random string and enter the SAME value in:
#   Razorpay Dashboard → Settings → Webhooks → + Add New Webhook → secret
RAZORPAY_WEBHOOK_SECRET=
# Plan IDs — create these in Razorpay Dashboard → Products → Subscriptions → Plans
RAZORPAY_PLAN_STARTER=       # plan_xxx  (₹999/mo)
RAZORPAY_PLAN_PRO=           # plan_xxx  (₹2499/mo)

# ── Vercel API (self-service clinic subdomain registration)
# Token: https://vercel.com/account/settings/tokens → Create Token (Full Account)
# Project ID: Vercel → mydentalplatform project → Settings → General → Project ID
VERCEL_TOKEN=
VERCEL_PROJECT_ID=

# ── App
# Public base URL of the platform (used in signup confirmation messages)
APP_BASE_URL=https://mydentalplatform.com

# ── Google Maps (optional)
# Used for address autocomplete in the clinic onboarding form.
# Enable "Maps JavaScript API" + "Places API" in Google Cloud Console.
# Restrict key to your domains (HTTP referrers) before deploying.
GOOGLE_MAPS_API_KEY=
