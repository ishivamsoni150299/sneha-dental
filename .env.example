# My Dental Platform environment variables
#
# Copy this file to .env.local for local development.
# Do not commit real secrets.

# Firebase Admin SDK
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# ElevenLabs
ELEVENLABS_API_KEY=
ELEVENLABS_WEBHOOK_SECRET=

# Retell AI outbound sales caller
RETELL_API_KEY=
# Must be a Retell-purchased or imported number in E.164 format, e.g. +14157774444
RETELL_FROM_NUMBER=
# MyDentalPlatform AI Sales Caller. Non-secret, but keep aligned with the live Retell agent.
RETELL_AGENT_ID=agent_347c0cd630b6ae7810d4c9b1fe
# Optional shared secret for Vobiz trunk webhooks. Send it as x-vobiz-webhook-secret if Vobiz supports custom headers.
VOBIZ_WEBHOOK_SECRET=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Deprecated legacy plan IDs - do not use for new subscriptions.
# Keep empty unless you need to inspect an old deployment.
RAZORPAY_PLAN_STARTER=
RAZORPAY_PLAN_PRO=

# Hosted subscription plans.
# Create fresh Razorpay plans for the current prices and set these exact IDs.
RAZORPAY_PLAN_STARTER_MONTHLY=plan_ShGxRJzXZynEts
RAZORPAY_PLAN_STARTER_YEARLY=
RAZORPAY_PLAN_PRO_MONTHLY=plan_ShGumDVvGT5kJz
RAZORPAY_PLAN_PRO_YEARLY=

# Manual backup payment link
PUBLIC_RAZORPAY_ME_URL=https://razorpay.me/@mydentalplatform

# Vercel API
VERCEL_TOKEN=
VERCEL_PROJECT_ID=

# App
APP_BASE_URL=https://www.mydentalplatform.com

# Optional integrations
GOOGLE_MAPS_API_KEY=
